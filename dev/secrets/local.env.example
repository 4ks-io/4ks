# Copy to dev/secrets/local.env and fill in the real values shared out-of-band.
# This file is consumed by dev/bootstrap-secrets.sh.

# Auth0 web app configuration
# Auth0 tenant settings must allow the v4 routes for this local host:
# - Allowed Callback URLs: https://local.4ks.io/auth/callback
# - Allowed Logout URLs: https://local.4ks.io
APP_BASE_URL=https://local.4ks.io
AUTH0_DOMAIN=4ks-dev.us.auth0.com
AUTH0_CLIENT_ID=eM5Zyyfp6coLg3zORMFsZEnQmpqxBjHd
AUTH0_CLIENT_SECRET=replace-me
AUTH0_SECRET=replace-me
# App-specific API audience, read by apps/web/src/libs/auth0.ts
AUTH0_AUDIENCE=https://local.4ks.io/api

# Local search defaults
TYPESENSE_API_KEY=local-4ks-api-key
TYPESENSE_URL=http://typesense.default.svc.cluster.local:8108

# Local utility defaults
GOOGLE_CLOUD_PROJECT=dev-4ks
FIRESTORE_DATABASE_ID=(default)

# Optional: point at the local Google application credentials file used by Tilt.
# Leave as-is if you already have the sandbox service account JSON at this path.
GOOGLE_APPLICATION_CREDENTIALS=dev/secrets/sbx-4ks-google-app-creds.json
